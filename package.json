{
  "name": "spa-smoke-test-action",
  "version": "1.0.0",
  "description": "GitHub action that runs very basic smoke tests for your single-page apps with Puppeteer",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "package": "ncc build dist/index.js --license licenses.txt --minify"
  },
  "keywords": [
    "spa",
    "single-page app",
    "webapp",
    "smoke test",
    "github",
    "action",
    "workflow"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=8.11.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "puppeteer-core": "^24.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
